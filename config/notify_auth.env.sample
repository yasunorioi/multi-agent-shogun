# 通知認証情報テンプレート
# コピーして config/notify_auth.env として使用
# cp config/notify_auth.env.sample config/notify_auth.env

# ntfy Bearer Token（セルフホスト用）
# NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ntfy Basic Auth（代替）
# NTFY_USER=username
# NTFY_PASS=password

# MQTT認証
# MQTT_USER=username
# MQTT_PASS=password
